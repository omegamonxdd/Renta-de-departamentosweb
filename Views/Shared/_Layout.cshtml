<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Noctis Real State — Descubre los departamentos de lujo más exclusivos. Vive la experiencia premium." />
    <title>@ViewData["Title"] — Noctis Real State</title>

    <!-- Google Fonts: Montserrat + Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">

    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- ══════════════════════════════════════════
         NAVBAR — Transparente / Sólida al scroll
         ══════════════════════════════════════════ -->
    <header>
        <nav class="noctis-navbar navbar navbar-expand-lg">
            <div class="container">

                <!-- Brand -->
                <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                    <span class="brand-icon">
                        <i class="bi bi-building-fill-check"></i>
                    </span>
                    Noctis Real State
                </a>

                <!-- Toggler -->
                <button class="navbar-toggler border-0" type="button"
                        data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Menú">
                    <span style="display:flex;flex-direction:column;gap:5px;">
                        <span style="display:block;width:22px;height:2px;background:#fff;border-radius:2px;"></span>
                        <span style="display:block;width:22px;height:2px;background:#fff;border-radius:2px;"></span>
                        <span style="display:block;width:14px;height:2px;background:#fff;border-radius:2px;"></span>
                    </span>
                </button>

                <!-- Links -->
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-lg-center gap-1 py-2 py-lg-0">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                Inicio
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Departamentos" asp-action="Disponibles">
                                Disponibles
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Departamentos" asp-action="Buscar">
                                Buscar
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Departamentos" asp-action="Index">
                                Administración
                            </a>
                        </li>
                        <li class="nav-item ms-lg-2">
                            <a class="btn-cta" asp-controller="Departamentos" asp-action="Create">
                                <i class="bi bi-plus-circle-fill"></i> Registrar
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <!-- ══════════════════════════════════════
         MAIN CONTENT
         ══════════════════════════════════════ -->
    <main role="main" class="noctis-main flex-grow-1">
        @RenderBody()
    </main>

    <!-- ══════════════════════════════════════
         FOOTER ELEGANTE
         ══════════════════════════════════════ -->
    <footer class="noctis-footer">
        <div class="container">
            <div class="row g-5">

                <!-- Brand & Tagline -->
                <div class="col-lg-4">
                    <div class="footer-brand">
                        <span class="brand-icon"><i class="bi bi-building-fill-check"></i></span>
                        Noctis Real State
                    </div>
                    <p class="footer-tagline">
                        Experiencias inmobiliarias de lujo. Encuentra tu hogar perfecto con nosotros.
                    </p>
                    <div class="d-flex gap-2 mt-3">
                        <a href="#" class="btn-icon btn-icon-view" style="border-color:rgba(255,255,255,0.2);color:rgba(255,255,255,0.55);" title="Instagram">
                            <i class="bi bi-instagram"></i>
                        </a>
                        <a href="#" class="btn-icon btn-icon-view" style="border-color:rgba(255,255,255,0.2);color:rgba(255,255,255,0.55);" title="Facebook">
                            <i class="bi bi-facebook"></i>
                        </a>
                        <a href="#" class="btn-icon btn-icon-view" style="border-color:rgba(255,255,255,0.2);color:rgba(255,255,255,0.55);" title="LinkedIn">
                            <i class="bi bi-linkedin"></i>
                        </a>
                    </div>
                </div>

                <!-- Navegación -->
                <div class="col-sm-6 col-lg-2">
                    <p class="footer-heading">Navegar</p>
                    <a class="footer-link" asp-controller="Home" asp-action="Index">Inicio</a>
                    <a class="footer-link" asp-controller="Departamentos" asp-action="Disponibles">Disponibles</a>
                    <a class="footer-link" asp-controller="Departamentos" asp-action="Buscar">Búsqueda</a>
                    <a class="footer-link" asp-controller="Departamentos" asp-action="Index">Administración</a>
                </div>

                <!-- Servicios -->
                <div class="col-sm-6 col-lg-2">
                    <p class="footer-heading">Servicios</p>
                    <a class="footer-link" href="#">Renta de lujo</a>
                    <a class="footer-link" href="#">Asesoría</a>
                    <a class="footer-link" href="#">Administración</a>
                    <a class="footer-link" href="#">Contacto</a>
                </div>

                <!-- Newsletter -->
                <div class="col-lg-4">
                    <p class="footer-heading">Suscríbete</p>
                    <p style="font-size:.875rem;color:rgba(255,255,255,.45);margin-bottom:1rem;">
                        Recibe las mejores propiedades antes que nadie.
                    </p>
                    <div class="d-flex footer-subscribe">
                        <input type="email" placeholder="tu@email.com" aria-label="Email suscripción">
                        <button type="button">
                            <i class="bi bi-send-fill"></i>
                        </button>
                    </div>
                </div>
            </div>

            <hr class="footer-divider">

            <div class="footer-bottom">
                <span>&copy; @DateTime.Now.Year Noctis Real State. Todos los derechos reservados.</span>
                <span>Desarrollado con <i class="bi bi-heart-fill text-accent" style="font-size:.75rem;"></i> para propiedades de lujo</span>
            </div>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <!-- Custom JS -->
    <script src="~/js/site.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
