@model RentaDepartamentosWeb.Models.Departamento

@{
    ViewData["Title"] = "Eliminar Departamento";

    var estadoBadgeClass = Model.Estado switch
    {
        "Disponible"    => "badge-disponible",
        "Rentado"       => "badge-rentado",
        "Mantenimiento" => "badge-mantenimiento",
        _               => "badge-otro"
    };
}

<div class="page-wrapper fade-in-up">
    <div class="container">

        <!-- Page Header -->
        <div class="page-header mb-4" style="background:linear-gradient(135deg,#7f1d1d,#991b1b);">
            <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
                <div>
                    <div class="page-header-icon" style="background:rgba(239,68,68,.15);border-color:rgba(239,68,68,.3);color:#fca5a5;">
                        <i class="bi bi-trash"></i>
                    </div>
                    <h1>Eliminar Departamento</h1>
                    <p>Esta acción no se puede deshacer. Verifica los datos antes de confirmar.</p>
                </div>
                <a asp-action="Index" class="btn-neutral" style="align-self:center;">
                    <i class="bi bi-arrow-left"></i> Volver al listado
                </a>
            </div>
        </div>

        <div class="noctis-form-card">
            <!-- Warning alert -->
            <div class="noctis-alert noctis-alert-warning mb-4">
                <i class="bi bi-exclamation-triangle-fill fs-5 flex-shrink-0"></i>
                <div>
                    <strong>¿Estás seguro?</strong> Estás a punto de eliminar permanentemente este departamento del sistema.
                </div>
            </div>

            <!-- Datos del departamento -->
            <div class="detail-row">
                <dt>Dirección</dt>
                <dd>@Model.Direccion</dd>
            </div>
            <div class="detail-row">
                <dt>Colonia</dt>
                <dd>@Model.Colonia</dd>
            </div>
            <div class="detail-row">
                <dt>Ciudad</dt>
                <dd>@Model.Ciudad</dd>
            </div>
            <div class="detail-row">
                <dt>Estado</dt>
                <dd><span class="noctis-badge @estadoBadgeClass">@Model.Estado</span></dd>
            </div>

            <hr class="divider my-4" />

            <form asp-action="Delete" asp-route-id="@Model.Id" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn-neutral">Cancelar</a>
                    <button type="submit" class="btn-danger-noctis">
                        <i class="bi bi-trash-fill"></i> Confirmar Eliminación
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>
