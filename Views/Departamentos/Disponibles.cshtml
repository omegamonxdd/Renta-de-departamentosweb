@model IEnumerable<RentaDepartamentosWeb.Models.Departamento>

@{
    ViewData["Title"] = "Departamentos Disponibles";
}

<div class="page-wrapper fade-in-up">
    <div class="container">

        <!-- Page Header -->
        <div class="page-header mb-4">
            <div class="page-header-icon">
                <i class="bi bi-check2-circle"></i>
            </div>
            <h1>Departamentos Disponibles</h1>
            <p>Explora las propiedades listas para rentar de inmediato.</p>
        </div>

        @if (!Model.Any())
        {
            <div class="empty-state">
                <i class="bi bi-inbox empty-icon"></i>
                <h3 class="h5 fw-bold mt-3" style="color:var(--color-dark)">Sin resultados</h3>
                <p>En este momento no hay departamentos disponibles.</p>
                <a asp-controller="Home" asp-action="Index" class="btn-cta mt-2">
                    <i class="bi bi-house-door"></i> Volver al inicio
                </a>
            </div>
        }
        else
        {
            <div class="row g-4">
                @foreach (var depto in Model)
                {
                    <div class="col-md-6 col-lg-4 reveal">
                        <div class="prop-card">
                            <!-- Imagen / Placeholder -->
                            <div class="card-img-wrap">
                                <div class="img-placeholder">
                                    <i class="bi bi-building"></i>
                                </div>
                                <!-- Badge disponible -->
                                <span class="status-badge noctis-badge badge-disponible">
                                    <i class="bi bi-circle-fill" style="font-size:.45rem;"></i> Disponible
                                </span>
                                <!-- Precio tag -->
                                <span class="price-tag">
                                    @depto.PrecioRenta.ToString("C0") <span style="font-size:.65rem;font-weight:400;opacity:.75;">/ mes</span>
                                </span>
                            </div>

                            <!-- Cuerpo -->
                            <div class="card-body">
                                <p class="prop-address">@depto.Direccion</p>
                                <p class="prop-location">
                                    <i class="bi bi-geo-alt"></i>
                                    @depto.Colonia, @depto.Ciudad
                                </p>

                                <!-- Stats: habitaciones, baños -->
                                <div class="prop-stats">
                                    <div class="prop-stat">
                                        <i class="bi bi-door-closed"></i>
                                        <span>@depto.Habitaciones hab.</span>
                                    </div>
                                    <div class="prop-stat">
                                        <i class="bi bi-droplet"></i>
                                        <span>@depto.Banios baño(s)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

    </div>
</div>
