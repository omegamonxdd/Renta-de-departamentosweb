@model RentaDepartamentosWeb.Models.Departamento

@{
    ViewData["Title"] = "Detalles del Departamento";

    var estadoBadgeClass = Model.Estado switch
    {
        "Disponible"    => "badge-disponible",
        "Rentado"       => "badge-rentado",
        "Mantenimiento" => "badge-mantenimiento",
        _               => "badge-otro"
    };
}

<div class="page-wrapper fade-in-up">
    <div class="container">

        <!-- Page Header -->
        <div class="page-header mb-4">
            <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
                <div>
                    <div class="page-header-icon">
                        <i class="bi bi-eye"></i>
                    </div>
                    <h1>Detalles del Departamento</h1>
                    <p>Información completa, solo lectura.</p>
                </div>
                <a asp-action="Index" class="btn-neutral" style="align-self:center;">
                    <i class="bi bi-arrow-left"></i> Volver al listado
                </a>
            </div>
        </div>

        <!-- Detail Card -->
        <div class="detail-card">
            <div class="detail-header">
                <h2>@Model.Direccion</h2>
                <span class="noctis-badge @estadoBadgeClass">@Model.Estado</span>
            </div>

            <div class="detail-body">
                <!-- Stats visuales -->
                <div class="d-flex gap-4 flex-wrap mb-4 pb-4" style="border-bottom:1px solid var(--color-slate-200);">
                    <div class="prop-stat">
                        <i class="bi bi-door-closed" style="font-size:1.25rem;"></i>
                        <div>
                            <div style="font-size:.75rem;color:var(--color-slate-400);font-weight:600;text-transform:uppercase;letter-spacing:.06em;">Habitaciones</div>
                            <div style="font-family:'Montserrat',sans-serif;font-size:1.4rem;font-weight:800;color:var(--color-dark);">@Model.Habitaciones</div>
                        </div>
                    </div>
                    <div class="prop-stat">
                        <i class="bi bi-droplet" style="font-size:1.25rem;"></i>
                        <div>
                            <div style="font-size:.75rem;color:var(--color-slate-400);font-weight:600;text-transform:uppercase;letter-spacing:.06em;">Baños</div>
                            <div style="font-family:'Montserrat',sans-serif;font-size:1.4rem;font-weight:800;color:var(--color-dark);">@Model.Banios</div>
                        </div>
                    </div>
                    <div class="prop-stat">
                        <i class="bi bi-tag" style="font-size:1.25rem;color:var(--color-accent);"></i>
                        <div>
                            <div style="font-size:.75rem;color:var(--color-slate-400);font-weight:600;text-transform:uppercase;letter-spacing:.06em;">Precio / mes</div>
                            <div style="font-family:'Montserrat',sans-serif;font-size:1.4rem;font-weight:800;color:var(--color-accent);">@Model.PrecioRenta.ToString("C2")</div>
                        </div>
                    </div>
                </div>

                <!-- Datos completos -->
                <div class="detail-row">
                    <dt>ID</dt>
                    <dd>@Model.Id</dd>
                </div>
                <div class="detail-row">
                    <dt>Dirección</dt>
                    <dd>@Model.Direccion</dd>
                </div>
                <div class="detail-row">
                    <dt>Colonia</dt>
                    <dd>@Model.Colonia</dd>
                </div>
                <div class="detail-row">
                    <dt>Ciudad</dt>
                    <dd>@Model.Ciudad</dd>
                </div>
                <div class="detail-row">
                    <dt>Estado</dt>
                    <dd><span class="noctis-badge @estadoBadgeClass">@Model.Estado</span></dd>
                </div>
                <div class="detail-row">
                    <dt>Arrendatario</dt>
                    <dd>@(string.IsNullOrWhiteSpace(Model.Arrendatario) ? "—" : Model.Arrendatario)</dd>
                </div>
                <div class="detail-row">
                    <dt>Inicio de renta</dt>
                    <dd>@(Model.FechaInicioRenta?.ToString("dd/MM/yyyy") ?? "—")</dd>
                </div>

                <!-- Acciones -->
                <div class="d-flex justify-content-end gap-2 mt-4 pt-3" style="border-top:1px solid var(--color-slate-200);">
                    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-cta">
                        <i class="bi bi-pencil"></i> Editar
                    </a>
                    <a asp-action="Index" class="btn-neutral">
                        <i class="bi bi-arrow-left"></i> Volver
                    </a>
                </div>
            </div>
        </div>

    </div>
</div>
