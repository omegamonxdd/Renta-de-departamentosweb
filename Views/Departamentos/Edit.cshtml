@model RentaDepartamentosWeb.Models.Departamento

@{
    ViewData["Title"] = "Editar Departamento";
}

<div class="page-wrapper fade-in-up">
    <div class="container">

        <!-- Page Header -->
        <div class="page-header mb-4">
            <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
                <div>
                    <div class="page-header-icon">
                        <i class="bi bi-pencil"></i>
                    </div>
                    <h1>Editar Departamento</h1>
                    <p>Modifica los datos de la propiedad y guarda los cambios.</p>
                </div>
                <a asp-action="Index" class="btn-neutral" style="align-self:center;">
                    <i class="bi bi-arrow-left"></i> Volver al listado
                </a>
            </div>
        </div>

        <div class="noctis-form-card">
            <form asp-action="Edit" asp-route-id="@Model.Id" method="post" novalidate>
                <div asp-validation-summary="ModelOnly" class="noctis-alert noctis-alert-danger mb-4" role="alert"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row g-4">
                    <div class="col-md-8">
                        <label asp-for="Direccion" class="form-label">Dirección</label>
                        <input asp-for="Direccion" class="form-control" />
                        <span asp-validation-for="Direccion" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Ciudad" class="form-label">Ciudad</label>
                        <input asp-for="Ciudad" class="form-control" />
                        <span asp-validation-for="Ciudad" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Colonia" class="form-label">Colonia</label>
                        <input asp-for="Colonia" class="form-control" />
                        <span asp-validation-for="Colonia" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Habitaciones" class="form-label">Habitaciones</label>
                        <input asp-for="Habitaciones" class="form-control" type="number" min="0" max="20" />
                        <span asp-validation-for="Habitaciones" class="text-danger small"></span>
                    </div>

                    <div class="col-md-3">
                        <label asp-for="Banios" class="form-label">Baños</label>
                        <input asp-for="Banios" class="form-control" type="number" min="0" max="20" />
                        <span asp-validation-for="Banios" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="PrecioRenta" class="form-label">Precio de renta</label>
                        <div class="input-group">
                            <span class="input-group-text">$</span>
                            <input asp-for="PrecioRenta" class="form-control" type="number" step="0.01" min="0.01" />
                        </div>
                        <span asp-validation-for="PrecioRenta" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <label asp-for="Estado" class="form-label">Estado</label>
                        <select asp-for="Estado" class="form-select" id="estadoSelect">
                            <option value="Disponible">Disponible</option>
                            <option value="Rentado">Rentado</option>
                            <option value="Mantenimiento">Mantenimiento</option>
                        </select>
                        <span asp-validation-for="Estado" class="text-danger small"></span>
                    </div>

                    <div class="col-md-4">
                        <!-- Reservado para alinear la cuadrícula en pantallas medianas -->
                    </div>

                    <div class="col-md-6" id="grupoArrendatario">
                        <label asp-for="Arrendatario" class="form-label">Nombre del arrendatario</label>
                        <input asp-for="Arrendatario" class="form-control" placeholder="Obligatorio si el estado es Rentado" />
                        <span asp-validation-for="Arrendatario" class="text-danger small"></span>
                    </div>

                    <div class="col-md-6" id="grupoFechaInicio">
                        <label asp-for="FechaInicioRenta" class="form-label">Fecha de inicio de renta</label>
                        <input asp-for="FechaInicioRenta" class="form-control" type="date" />
                        <span asp-validation-for="FechaInicioRenta" class="text-danger small"></span>
                    </div>
                </div>

                <hr class="divider my-4" />

                <div class="d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn-neutral">Cancelar</a>
                    <button type="submit" class="btn-cta">
                        <i class="bi bi-check2-circle"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.20.1/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@4.0.0/dist/jquery.validate.unobtrusive.min.js"></script>
    <script>
        (function () {
            const estadoSelect = document.getElementById('estadoSelect');
            const grupoArrendatario = document.getElementById('grupoArrendatario');
            const grupoFechaInicio = document.getElementById('grupoFechaInicio');

            function actualizarVisibilidad() {
                const esRentado = estadoSelect.value === 'Rentado';
                grupoArrendatario.style.display = esRentado ? '' : 'none';
                grupoFechaInicio.style.display = esRentado ? '' : 'none';
            }

            estadoSelect.addEventListener('change', actualizarVisibilidad);
            actualizarVisibilidad();
        })();
    </script>
}
